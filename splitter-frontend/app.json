{
  "expo": {
    "name": "Receipt Splitter",
    "slug": "receipt-splitter",
    "icon": "./assets/icon.png",
    "scheme": "receipt-splitter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "backgroundColor": "#0a0a0f",
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#0a0a0f",
      "bundleIdentifier": "com.jduapp.receiptsplitter"
    },
    "android": {
      "package": "com.jduapp.receiptsplitter",
      "backgroundColor": "#0a0a0f",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-localization",
      "expo-font",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05fc7a2d-813f-4121-9103-860ef1313a37"
      }
    },
    "owner": "jduapp"
  }
}
